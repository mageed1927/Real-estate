<odoo>

    <record id="al_mohamady_report" model="ir.actions.report">
        <field name="name">Get Report</field>
        <field name="model">my.app</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">testapp.al_mohamady_report_view</field>
        <field name="report_file">testapp.al_mohamady_report_view</field>
        <field name="binding_model_id" ref="model_my_app" />
        <field name="binding_type">report</field>
    </record>

    <template id="al_mohamady_report_view">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="my">
                <t t-call="web.internal_layout">
                    <div class="page">
                        <h1>al mohamady report</h1>
                        <p>
                            name
                            <sapn t-field="my.name" />
                        </p>
                        <p>
                            age
                            <sapn t-field="my.value" />
                        </p>
                        <p>
                            salary
                            <sapn t-field="my.value2" />
                        </p>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>