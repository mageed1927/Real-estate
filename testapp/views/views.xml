<odoo>
  <data>
    <!-- explicit list view definition -->

    <record model="ir.ui.view" id="testapp_am_list">
      <field name="name">Misurati list</field>
      <field name="model">my.app</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name"/>
          <field name="value"/>
          <field name="value2"/>
          <field name="description"/>
          <field name="truefalse"/>
          <field name="date"/>
          <field name="date_time"/>
        </tree>
      </field>
    </record>


    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="testapp_misurati_action_window">
      <field name="name">misurati</field>
      <field name="res_model">my.app</field>
      <field name="view_mode">tree,form,kanban,pivot,graph</field>
    </record>

    <record model="ir.actions.act_window" id="testapp_orders_action_window">
      <field name="name">Orders</field>
      <field name="res_model">my.orders</field>
      <field name="view_mode">tree,form</field>
    </record>

    <record model="ir.actions.act_window" id="testapp_items_action_window">
      <field name="name">Items</field>
      <field name="res_model">my.orders.items</field>
      <field name="view_mode">tree,form</field>
    </record>


    <!-- server action to the one above -->
<!--
    <record model="ir.actions.server" id="testapp.action_server">
      <field name="name">testapp server</field>
      <field name="model_id" ref="model_testapp_testapp"/>
      <field name="state">code</field>
      <field name="code">
        action = {
          "type": "ir.actions.act_window",
          "view_mode": "tree,form",
          "res_model": model._name,
        }
      </field>
    </record>
-->

    <!-- Top menu item -->

    <menuitem name="New app" id="testapp.menu_root"/>

    <!-- menu categories -->

    <menuitem name="main" id="testapp.menu_main" parent="testapp.menu_root"
              action="testapp_misurati_action_window"/>
    <menuitem name="My Orders" id="testapp.menu_orders" parent="testapp.menu_root"/>

    <!-- actions -->

    <menuitem name="Orders" id="testapp.menu_order_list" parent="testapp.menu_orders"
              action="testapp_orders_action_window"/>
    <menuitem name="items" id="testapp.menu_order_item_list" parent="testapp.menu_orders"
              action="testapp_items_action_window"/>

  </data>
</odoo>
