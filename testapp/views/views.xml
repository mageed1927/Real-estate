<odoo>
  <data>
    <!-- explicit list view definition -->

    <record model="ir.ui.view" id="testapp_am_list">
      <field name="name">alMohamady list</field>
      <field name="model">my.app</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name"/>
          <field name="value" string="age"/>
          <field name="value2" string="salary" sum="salary"/>
          <field name="description" decoration-bf="1"/>
          <field name="trueFalse" string="isActive"/>
          <field name="date" icon="fa-bell-slash" optional="show"/>
          <field name="date_time" optional="hide"/>
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="testapp_am_form">
      <field name="name">alMohamady from</field>
      <field name="model">my.app</field>
      <field name="arch" type="xml">
        <form string="My Form">
          <header>
            <!-- Fixed Odoo 17 States Here -->
            <button name='event_reviewed' string='Reviewed' type='object' invisible="state != 'new'" />
            <button name='event_approved' string='Approved' type='object' invisible="state != 'reviewed'" />
            <button name='event_refused' string='Refused' type='object' invisible="state != 'reviewed'" />
            <field name="state" widget="statusbar" />
          </header>
          <sheet>
            <h1>hello world</h1>
            <h2><field name="name" default_focus="1" placeholder="enter the name"/></h2>
            <hr />
             <group>
               <group string="info 01">
                 <field name="value" string="age" decoration-bf="1"/>
                 <field name="value2" string="salary"/>
                 <field name="selection" string="Select level"/>
               </group>
               <group string="info 02">
                 <field name="trueFalse" string="isActive"/>
                 <field name="date" icon="fa-bell-slash"/>
                 <field name="date_time"/>
               </group>
             </group>
            <group string="calculator">
              <field name="col1"/>
              <field name="col2"/>
              <hr /><br />
              <field name="result"/>
              <field name="computed"/>
            </group>
            <notebook>
              <page string="html scheme">
                <group>
                  <field name="html"/>
                </group>
              </page>
              <page string="notes" >
                <group>
                  <field name="description" />
                </group>
              </page>
            </notebook>
          </sheet>
          <div class="oe_chatter">
            <field name="message_follower_ids" />
            <field name="activity_ids" />
            <field name="message_ids" />
          </div>
        </form>
      </field>
    </record>

    <record model="ir.ui.view" id="testapp_am_orders_form">
      <field name="name">orders from</field>
      <field name="model">my.order</field>
      <field name="arch" type="xml">
        <form string="My Order">
          <header>
            <button name="get_query" string="query" type="object" />
            <!-- Fixed Odoo 17 States Here -->
            <button name="add_item" string="add item" type="object" invisible="state != 'ready'" />
            <button name='event_ready' string='Ready' type='object' invisible="state != 'new'" />
            <field name="state" widget="statusbar" />
          </header>
          <sheet>
             <group>
                <field name="name" string="Oder Name" />
                <field name="date_time" string="Order Date"/>
                <field name="isActive" string="Is Active"/>
                <field name="items_ids" string="Items" />
             </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- actions opening views on models -->

    <record model="ir.actions.act_window" id="testapp_almohamady_action_window">
      <field name="name">almohamady</field>
      <field name="res_model">my.app</field>
      <field name="view_mode">tree,form,kanban,pivot,graph</field>
    </record>

    <record model="ir.actions.act_window" id="testapp_orders_action_window">
      <field name="name">orders</field>
      <field name="res_model">my.order</field>
      <field name="view_mode">tree,form</field>
    </record>

    <record model="ir.actions.act_window" id="testapp_items_action_window">
      <field name="name">items</field>
      <field name="res_model">my.orders.items</field>
      <field name="view_mode">tree,form</field>
    </record>

    <!-- Top menu item -->

    <menuitem name="almohamady" id="testapp.menu_root"/>

    <!-- menu categories -->

    <menuitem name="mohamady main" id="testapp_menu_am_main" parent="testapp.menu_root"
              action="testapp_almohamady_action_window"/>
    <menuitem name="My Orders" id="testapp_menu_am_orders" parent="testapp.menu_root"/>

    <!-- actions -->

    <menuitem name="Orders" id="testapp_menu_am_order_list" parent="testapp_menu_am_orders"
              action="testapp_orders_action_window"/>
    <menuitem name="Items" id="testapp_menu_am_order_item_list" parent="testapp_menu_am_orders"
              action="testapp_items_action_window"/>

  </data>
</odoo>