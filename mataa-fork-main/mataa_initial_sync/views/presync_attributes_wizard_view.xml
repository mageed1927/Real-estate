<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_presync_attributes_wizard" model="ir.ui.view">
            <field name="name">presync.attributes.wizard.form</field>
            <field name="model">presync.attributes.wizard</field>
            <field name="arch" type="xml">
                <form string="PreSync Attributes">
                    <group>
                        <field name="import_file" widget="binary" filename="file_name"/>
                        <field name="file_name"/>
                    </group>
                    <footer>
                        <button string="Import" type="object" name="presync_attributes" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_presync_attributes" model="ir.actions.act_window">
            <field name="name">PreSync Attributes</field>
            <field name="res_model">presync.attributes.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_presync_attributes"
                  name="PreSync Attributes"
                  parent="menu_initial_sync_root"
                  action="action_presync_attributes"
                  sequence="20"/>
    </data>
</odoo>