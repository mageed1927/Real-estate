<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!--Sale Order-->
        <record id="camex_view_order_form_inherit" model="ir.ui.view">
            <field name="name">sale.camex.order.form.inherit.mataa</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <group name="sale_info" position="inside">
                    <field name="camex_shipment_state"/>
                </group>
            </field>
        </record>

        <record id="sale_order_tree_inherit_camex_delivery" model="ir.ui.view">
            <field name="name">sale.order.tree.camex.delivery</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.sale_order_tree"/>
            <field name="arch" type="xml">
                <field name="amount_total" position="after">
                    <field name="camex_shipment_state" optional="hide"/>
                </field>
            </field>
        </record>

    </data>
</odoo>
