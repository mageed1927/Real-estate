<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit res.config.settings form view to add VMS configuration -->
        <record id="res_config_settings_vms_form" model="ir.ui.view">
            <field name="name">res.config.settings.vms.form</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="purchase.res_config_settings_view_form_purchase"/>
            <field name="arch" type="xml">
                <!-- Add VMS section after the General section -->
                <block name="purchase_setting_container" position="after">
                    <block title="Mataa VMS" name="purchase_setting_container">

                        <setting id="account_payable_inhouse_id"
                                 help="This account will be used to record the initial liability for goods received from in-house vendors."
                                 title="Payable Account for In-House Vendor">
                            <field name="account_payable_inhouse_id"/>
                        </setting>

                        <setting id="vms_auto_clearance"
                                 help="Automatically create clearance entries when orders are closed">
                            <field name="vms_auto_clearance"/>
                        </setting>

                        <setting id="vms_auto_bill_creation"
                                 help="Automatically create vendor bills when orders are closed">
                            <field name="vms_auto_bill_creation"/>
                        </setting>

                        <setting id="vendor_clearance_journal_id" help="Journal to use for vendor clearance entries">
                            <field name="vendor_clearance_journal_id"/>
                        </setting>

                    </block>
                </block>

            </field>
        </record>

    </data>
</odoo>
