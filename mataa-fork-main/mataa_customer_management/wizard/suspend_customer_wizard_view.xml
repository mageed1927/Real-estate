<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_suspend_customer_wizard_form" model="ir.ui.view">
            <field name="name">suspend.customer.wizard.form</field>
            <field name="model">suspend.customer.wizard</field>
            <field name="arch" type="xml">
                <form string="Suspend Customer">
                    <group>
                        <field name="reason"/>
                    </group>
                    <footer>
                        <button string="Suspend" type="object" name="action_confirm" class="btn-primary"/>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
            </record>
    </data>
</odoo>