<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_delivery_carrier_form_with_provider_line" model="ir.ui.view">
        <field name="name">delivery.carrier.form.provider.line</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='destination']" position='before'>
                <page string="Line Configuration" name="camex_configuration"
                      invisible="delivery_type != 'line'">
                    <group>
                        <group>
                            <field name="line_base_url" required="delivery_type == 'line'"/>
                            <field name="line_username" required="delivery_type == 'line'"/>
                            <field name="line_password" required="delivery_type == 'line'"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
