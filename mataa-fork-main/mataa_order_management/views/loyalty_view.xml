<odoo>
    <record id="loyalty_rule_form_inherit_alt" model="ir.ui.view">
        <field name="name">loyalty.rule.form.customer.restrictions.alt</field>
        <field name="model">loyalty.rule</field>
        <field name="inherit_id" ref="loyalty.loyalty_rule_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='reward_point_mode']" position="after">
                <group string="Customers" name="customer_restrictions">
                    <field name="customer_ids" widget="many2many_tags"
                           placeholder="Leave empty to apply to all customers"
                           options="{'no_create_edit': True}"
                           colspan="4"
                           nolabel="1"/>
                    <field name="usage_limit_per_customer" class="oe_inline" colspan="2"/>
                </group>
            </xpath>

            <xpath expr="//group[.//field[@name='product_ids']]" position="after">
              <group string="Brand / Vendor / Website">
                <field name="brand_ids" widget="many2many_tags"/>
                <field name="vendor_ids" widget="many2many_tags"/>
                <field name="website_categ_ids" widget="many2many_tags"/>
              </group>
            </xpath>

            <xpath expr="//sheet//group[last()]" position="after">
              <group string="Shipping / التوصيل">
                <field name="limit_free_shipping_by_city"/>
                <field name="allowed_city_ids"
                       invisible="not limit_free_shipping_by_city"
                       widget="many2many_tags"/>
              </group>
            </xpath>

        </field>
    </record>
</odoo>