<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_loyalty_reward_form_inherit_cap" model="ir.ui.view">
      <field name="name">loyalty.reward.form.cap</field>
      <field name="model">loyalty.reward</field>
      <field name="inherit_id" ref="loyalty.loyalty_reward_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//group" position="inside">
          <field name="discount_type"/>
          <field name="discount_percentage"
                 invisible="discount_type != 'percent'"/>
          <field name="max_discount_amount"
                 invisible="discount_type != 'percent'"/>
        </xpath>
      </field>
    </record>
</odoo>