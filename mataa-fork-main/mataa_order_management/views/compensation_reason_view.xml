<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="compensation_reason_view_tree" model="ir.ui.view">
        <field name="name">compensation.reason.view.tree</field>
        <field name="model">compensation.reason</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="action_compensation_reason" model="ir.actions.act_window">
        <field name="name">Compensation Reasons</field>
        <field name="res_model">compensation.reason</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem id="menu_compensation_reason"
              name="Compensation Reasons"
              parent="sale.menu_sale_config"
              action="action_compensation_reason"
              sequence="50"/>
</odoo> 