<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_inventory_valuation_search_inherit_brand" model="ir.ui.view">
        <field name="name">stock.valuation.layer.search.inherit</field>
        <field name="model">stock.valuation.layer</field>
        <field name="inherit_id" ref="stock_account.view_inventory_valuation_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="brand_id"/>
            </xpath>
            <xpath expr="//filter[@name='group_by_product_id']" position="after">
                <filter string="Product Brand" name="group_by_brand" context="{'group_by': 'brand_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>