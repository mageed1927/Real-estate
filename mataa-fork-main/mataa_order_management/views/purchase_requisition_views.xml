<odoo>
    <data>
        <record id="purchase_requisition_form_view_inherit" model="ir.ui.view">
            <field name="name">purchase_requisition.form.view.inherit</field>
            <field name="model">purchase.requisition</field>
            <field name="inherit_id" ref="purchase_requisition.view_purchase_requisition_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <group string="Totals">
                        <field name="total_ordered_qty" readonly="1"/>
                        <field name="total_accepted_qty" readonly="1"/>
                    </group>
                    <group>
                        <field name="external_id" readonly="1" string="Dtrack id"/>
                        <field name="prevent_line_addition" readonly="0" string="prevent adding lines"/>
                    </group>
                </xpath>
                <xpath expr="//header//button[@name='action_in_progress']" position="replace">
                    <button name="send_to_dtrack"
                            string="Send to Dtrack"
                            type="object"
                            class="btn-primary"
                            invisible="external_id != False"
                    />
                </xpath>
                <xpath expr="//field[@name='picking_type_id']" position="after">
                    <field name="total_ordered_qty" readonly="1"/>
                    <field name="total_accepted_qty" readonly="1"/>
                </xpath>
                <xpath expr="//form" position="attributes">
                    <attribute name="create">0</attribute>
                    <attribute name="delete">0</attribute>
                    <attribute name="duplicate">0</attribute>
                    <attribute name="readonly">external_id != False</attribute>
                </xpath>
                <xpath expr="//field[@name='line_ids']" position="attributes">
                    <attribute name="readonly">external_id != False</attribute>
                </xpath>

                <field name="product_qty" position="attributes">
                    <attribute name="optional">hide</attribute>
                </field>

                <field name="qty_ordered" position="attributes">
                    <attribute name="optional">hide</attribute>
                </field>

                <field name="product_description_variants" position="after">
                    <field name="po_id" optional="show"/>
                    <field name="so_id" optional="show"/>
                    <field name="ordered_qty"/>
                    <field name="accepted_qty"/>
                    <field name="rejected_qty" readonly="1"/>
                </field>
            </field>
        </record>

        <record id="purchase_requisition_tree_view_inherit" model="ir.ui.view">
            <field name="name">purchase_requisition.tree.view.inherit</field>
            <field name="model">purchase.requisition</field>
            <field name="inherit_id" ref="purchase_requisition.view_purchase_requisition_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//tree" position="attributes">
                    <attribute name="import">0</attribute>
                    <attribute name="create">0</attribute>
                    <attribute name="delete">0</attribute>
                    <attribute name="duplicate">0</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>