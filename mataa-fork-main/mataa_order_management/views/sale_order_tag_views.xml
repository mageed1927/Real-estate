<?xml version="1.0"?>
<odoo>

    <record id="so_tag_view_form" model="ir.ui.view">
        <field name="name">so.tag.view.form</field>
        <field name="model">so.tag</field>
        <field name="arch" type="xml">
            <form string="Tags">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Services"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="color" required="True" widget="color_picker"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="so_tag_view_tree" model="ir.ui.view">
        <field name="name">so.tag.view.tree</field>
        <field name="model">so.tag</field>
        <field name="arch" type="xml">
            <tree string="Tags" editable="bottom" sample="1">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </tree>
        </field>
    </record>

    <!-- Tags Configuration -->
    <record id="so_tag_action" model="ir.actions.act_window">
        <field name="name">Mataa SO Tags</field>
        <field name="res_model">so.tag</field>
        <field name="view_id" ref="so_tag_view_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create SO Tags
            </p>
            <p>
                Use Tags to manage and track your Quotation
            </p>
        </field>
    </record>

    <menuitem
            id="menu_so_tag"
            name="Mataa SO Tags"
            action="mataa_order_management.so_tag_action"
            parent="sale.menu_sales_config"
            sequence="1"/>

</odoo>
