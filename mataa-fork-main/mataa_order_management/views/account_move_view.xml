<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_move_bill_form_inherit" model="ir.ui.view">
            <field name="name">account.move.inherit.purchase</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet/group[1]" position="before">
                    <div>
                        <field name="price_above_last_purchase_alert" widget="html" readonly="1" nolabel="1"/>
                        <field name="price_below_cost_alert" widget="html" readonly="1" nolabel="1"/>
                    </div>
                </xpath>
<!--                <xpath expr="//field[@name='amount_total']" position="before">-->
<!--                    <field name="total_quantity" readonly="1"/>-->
<!--                </xpath>-->

                <xpath expr="//div[@name='button_box']" position="inside">
                    <button class="oe_stat_button"
                            name="action_view_related_sale_orders"
                            type="object"
                            icon="fa-pencil-square-o"
                            invisible="related_sale_order_count == 0">
                        <field string="Sales" name="related_sale_order_count" widget="statinfo"/>
                    </button>
                </xpath>
                <group id="header_right_group" position="inside">
                    <field name="related_sale_order_id"/>
                    <field name="total_quantity" readonly="1"/>
                </group>

<!--                <xpath expr="//field[@name='related_sale_order_id']" position="after">-->
<!--                    <field name="total_quantity" readonly="1"/>-->
<!--                </xpath>-->
            </field>
        </record>

        <record id="view_move_form_inherit_mataa" model="ir.ui.view">
            <field name="name">account.move.form.inherit.mataa</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='account_id']" position="after">
                    <field name="product_description_variants" optional="show"
                           column_invisible="[('parent.move_type', '!=', 'in_invoice')]"/>
                    <field name="po_name" optional="show"
                           column_invisible="[('parent.move_type', '!=', 'in_invoice')]"/>
                    <field name="so_id" optional="show"
                           column_invisible="[('parent.move_type', '!=', 'in_invoice')]"/>
                </xpath>
            </field>
        </record>
          <record id="view_account_payment_search_inherited" model="ir.ui.view">
            <field name="name">account.payment.search.inherited</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_search"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='journal_id']" position="after">
                    <field name="id" string="Search by ID"/>
                </xpath>
            </field>
        </record>
         <record id="view_account_payment_search_inherited_domain" model="ir.ui.view">
            <field name="name">account.payment.search.inherited.domain</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_search"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="attributes">
                    <attribute name="filter_domain">
                        ['|', '|', '|', '|', '|', ('name', 'ilike', self), ('partner_id', 'ilike', self), ('ref', 'ilike', self), ('amount_company_currency_signed', 'ilike', self), ('amount', 'ilike', self), ('id', 'ilike', self)]
                    </attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>