<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="purchase_order_form_view_inherit" model="ir.ui.view">
            <field name="name">purchase_order.form.view.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">

                <xpath expr="//div[@name='button_box']" position="after">
                    <widget
                            name="web_ribbon"
                            title="Archived"
                            bg_color="bg-danger"
                            invisible="active"
                    />
                </xpath>
                <xpath expr="//sheet">
                    <field name="active" invisible="1"/>
                </xpath>

                <field name="picking_type_id" position="after">
                    <field name="internal_note" placeholder="Add any internal notes here..."/>
                </field>

                <xpath expr="//form" position="attributes">
                    <attribute name="delete">0</attribute>
                </xpath>
                <xpath expr="//header" position="inside">
                    <button name="action_split_rfq" string="Split RFQ" type="object" class="btn-primary"
                            invisible="state != 'draft' or sale_order_id == False"/>
                </xpath>
                <xpath expr="//button[@id='draft_confirm']" position="replace">
                    <button name="button_confirm" type="object" invisible="state != 'draft' or sale_order_id != False"
                            context="{'validate_analytic': True}" string="Confirm Order" id="draft_confirm"
                            data-hotkey="q"/>
                </xpath>
                <xpath expr="//button[@name='button_cancel']" position="replace">
                    <button name="button_cancel"
                            invisible="state not in ('draft', 'to approve', 'sent', 'purchase') or sale_order_state not in (False, 'cancel')"
                            string="Cancel" type="object" data-hotkey="x"/>
                </xpath>
                <xpath expr="//button[@name='button_approve']" position="replace">
                    <button name="button_approve" type="object"
                            invisible="state != 'to approve' or sale_order_id != False"
                            string="Approve Order"
                            class="oe_highlight" data-hotkey="z"/>
                </xpath>
                <xpath expr="//field[@name='partner_ref']" position="after">
                    <field name="sale_order_id"/>
                    <field name="mataa_tag_ids" widget="many2many_tags" options="{'color_field': 'color', 'no_create_edit': True}"/>
                    <field name="customer_tag_ids" widget="many2many_tags" options="{'color_field': 'color', 'no_create_edit': True}"/>
                    <field name="mataa_picking_ids" invisible="1"/>
                    <field name="sale_order_state" invisible="1"/>
                </xpath>

                <xpath expr="//notebook//page[@name='products']//field[@name='order_line']//tree//field[@name='sequence']"
                       position="after">
                    <field name="so_line_image" widget="image_url" style="height:30px ;width:30px;" readonly="1"/>
                </xpath>

                <xpath expr="//notebook//page[@name='products']//field[@name='order_line']//tree//field[@name='product_qty']"
                       position="after">
                    <field name="available_qty" readonly="state not in ['draft', 'sent']"/>
                    <field name="reason" readonly="state not in ['draft', 'sent']"/>
                    <field name="available_date" readonly="state not in ['draft', 'sent']"/>
                    <field name="note" readonly="state not in ['draft', 'sent']"/>
                </xpath>
                <xpath expr="//field[@name='order_line']/tree/field[@name='note']" position="after">
                    <field name="last_purchase_date"/>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="readonly">state not in ['draft', 'sent']</attribute>
                </xpath>
                <xpath expr="//field[@name='order_line']" position="attributes">
                    <attribute name="readonly">state not in ['draft', 'sent']</attribute>
                </xpath>
<!--                <xpath expr="//sheet/notebook" position="after">-->
<!--                    <div class="oe_subtotal_footer" name="mataa_total_quantity" style="text-align:right">-->
<!--                        <label for="total_quantity" class="o_form_label">Total Quantity</label>-->
<!--                        <field name="total_quantity" readonly="1"/>-->
<!--                    </div>-->
<!--                </xpath>-->
                <xpath expr="//field[@name='internal_note']" position="after">
                    <field name="total_quantity" readonly="1"/>
                </xpath>

                <xpath expr="//field[@name='user_id']" position="attributes">
                    <attribute name="readonly">state not in ['draft', 'sent']</attribute>
                </xpath>
                <xpath expr="//notebook//page[@name='products']//field[@name='order_line']//tree//field[@name='name']"
                       position="after">
                    <field name="package_name" optional="show"/>
                </xpath>
            </field>
        </record>
        <record id="purchase_order_form_inherit_purchase_requisition_mataa" model="ir.ui.view">
            <field name="name">purchase.order.form.inherit.purchase.requisition.mataa</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase_requisition.purchase_order_form_inherit"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='alternative_pos']" position="replace">
                    <!--                    hiding the 'Alternatives' tab-->
                </xpath>
                <xpath expr="//field[@name='requisition_id']" position="attributes">
                    <attribute name="readonly">state not in ['draft', 'sent']</attribute>
                </xpath>
            </field>
        </record>
        <record id="view_purchase_order_tree_inherit" model="ir.ui.view">
            <field name="name">purchase.order.tree.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//tree" position="attributes">
                    <attribute name="delete">0</attribute>
                </xpath>
                <field name="date_order" position="after">
                    <field name="internal_note" optional="show"/>
                </field>
            </field>
        </record>

        <record id="view_purchase_order_archive_filter" model="ir.ui.view">
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <separator/>
                    <filter
                            string="Archived"
                            name="inactive"
                            domain="[('active','=',False)]"
                    />
                </xpath>
            </field>
        </record>

    </data>
</odoo>
