<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="mataa_sales_order_paperformat" model="report.paperformat">
            <field name="name">A5 - Mataa Sales Order</field>
            <field name="default" eval="True"/>
            <field name="format">A5</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">50</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">1</field>
            <field name="margin_right">1</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">45</field>
            <field name="dpi">90</field>
        </record>


        <record id="mataa_sales_order" model="ir.actions.report">
            <field name="name">A5 Sales Order</field>
            <field name="model">sale.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">mataa_order_management.mataa_report_saleorder</field>
            <field name="report_file">mataa_order_management.mataa_report_saleorder</field>
            <field name="paperformat_id" ref="mataa_order_management.mataa_sales_order_paperformat"/>
            <field name="print_report_name">(object.state in ('draft', 'sent') and 'Quotation - %s' % (object.name)) or 'Order - %s' % (object.name)</field>
            <field name="attachment"/>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="binding_type">report</field>
        </record>

    </data>
</odoo>
