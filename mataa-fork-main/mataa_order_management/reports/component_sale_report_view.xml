<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_component_sale_report_pivot" model="ir.ui.view">
            <field name="name">component.sale.report.pivot</field>
            <field name="model">component.sale.report</field>
            <field name="arch" type="xml">
                <pivot string="Kit Products Report">
                   <field name="product_tmpl_id" type="row"/>
                   <field name="component_product_id" type="row"/>
                   <field name="supplier_id" invisible="1"/>
                   <field name="order_date" type="col" interval="month"/>
                   <field name="qty_kit" type="measure"/>
                   <field name="qty_component" type="measure"/>
                   <field name="price_total" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="action_component_sale_report" model="ir.actions.act_window">
            <field name="name">Kit Products Report</field>
            <field name="res_model">component.sale.report</field>
            <field name="view_mode">pivot</field>
        </record>

        <menuitem id="menu_component_sale_report"
                  name="Kit Products Report"
                  parent="sale.menu_sale_report"
                  action="action_component_sale_report"
                  sequence="11"/>
    </data>
</odoo>