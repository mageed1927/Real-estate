<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="report_saleorder_document_inherit" inherit_id="sale.report_saleorder_document">

            <th t-if="display_discount" position="replace"/>
            <td t-if="display_discount" position="replace"/>

            <th name="th_taxes" position="replace"/>
            <td name="td_taxes" position="replace"/>

            <span t-field="line.name" position="replace">
                <span t-field="line.product_id"/>
            </span>

            <span t-field="doc.note" position="replace"/>
            <p t-if="not is_html_empty(doc.payment_term_id.note)" position="replace"/>

        </template>


        <!--====================================================================================-->

        <template id="mataa_report_saleorder_document">
            <t t-call="mataa_order_management.mataa_new_layout">
                <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)"/>
                <t t-set="so_id" t-value="doc"/>

                <div class="page" dir="rtl" style="font-size:12px; font-family: Calibiri;">
                    <div class="oe_structure"/>


                    <t t-set="lines_to_report" t-value="doc._get_order_lines_to_report()"/>

                    <div class="oe_structure"/>
                    <div t-if="so_id.mataa_customer_note">
                        <p>ملاحظة العميل:</p>
                        <span t-field="so_id.mataa_customer_note"/>
                    </div>
                    <table class="table table-sm o_main_table mt-4">
                        <!-- In case we want to repeat the header, remove "display: table-row-group" -->
                        <thead style="background-color: #f0f1f2; table-borderless">
                            <tr>
                                <th name="th_num" class="text-center">#</th>
                                <th name="th_image" class="text-center"/>
                                <th name="th_p_code" class="text-center">كود المنتج</th>
                                <th name="th_location" class="text-center">الموقع</th>
                                <th name="th_barcode" class="text-center">الباركود</th>
                                <th name="th_p_name" class="text-center">اسم المنتج</th>
                                <th name="th_quantity" class="text-center">الكمية</th>
                                <th name="th_priceunit" class="text-center">سعر الوحدة</th>
                                <th name="th_subtotal" class="text-center">السعر</th>
                            </tr>
                        </thead>
                        <tbody class="sale_tbody">
                            <t t-set="i" t-value="0"/>
                            <t t-set="total_qty" t-value="0"/>
                            <t t-set="total_amount" t-value="0"/>
                            <t t-set="i" t-value="0"/>
                            <t t-foreach="lines_to_report.filtered(lambda x: not x.is_delivery and (x.product_uom_qty != 0 or x.product_uom_qty  &lt; 0))" t-as="line">
                                <t t-set="i" t-value="i + 1"/>
                                <tr>
                                    <t t-if="not line.display_type">
                                        <t t-set="total_qty" t-value="total_qty + line.product_uom_qty"/>
                                        <t t-set="total_amount" t-value="total_amount + line.price_subtotal"/>
                                        <td name="td_num">
                                            <span t-esc="i"/>
                                        </td>
                                        <td name="td_image">
                                            <span>
                                                <img t-att-src="line.so_line_main_image"
                                                     alt="Product Image" style="max-height:100px; max-width:80px;"/>

                                            </span>
                                        </td>
                                        <td name="td_p_code">
                                            <span t-field="line.product_id.default_code"/>
                                        </td>
                                       <td name="td_location" class="text-center">

                                            <t t-set="move_line"
                                               t-value="
                                                   doc.picking_ids.mapped('move_line_ids').filtered(
                                                       lambda ml:
                                                           ml.product_id.id == line.product_id.id
                                                           and ml.location_id.complete_name.startswith('WH/Stock')
                                                   )[:1]
                                               "/>

                                            <t t-if="move_line">
                                                <t t-if="move_line.package_id">
                                                    <span t-esc="move_line.package_id.name"/>
                                                </t>
                                                <t t-else="">
                                                    <span t-esc="move_line.location_id.complete_name"/>
                                                </t>

                                            </t>

                                            <t t-else="">
                                                <t t-set="quant"
                                                   t-value="
                                                       line.product_id.stock_quant_ids.filtered(
                                                           lambda q:
                                                               q.location_id.complete_name.startswith('WH/Stock')
                                                               and q.location_id.usage == 'internal'
                                                       )[:1]
                                                   "/>

                                                <t t-if="quant">

                                                    <t t-if="quant.package_id">
                                                        <span t-esc="quant.package_id.name"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-esc="quant.location_id.complete_name"/>
                                                    </t>
                                                </t>
                                                <t t-else="">
                                                    <span>-</span>
                                                </t>
                                            </t>
                                        </td>
                                        <td name="td_barcode" class="text-center">
                                            <span t-field="line.product_id.barcode"/>
                                        </td>
                                        <td name="td_p_name">
                                            <span t-field="line.product_id.name"/>
                                        </td>
                                        <td name="td_quantity" class="text-end">
                                            <span t-field="line.product_uom_qty" t-options='{"widget": "integer"}'/>
                                        </td>
                                        <td name="td_priceunit" class="text-end">
                                            <t t-if="line.discount">
                                                <p t-esc="int(line.price_unit - (line.price_unit * line.discount / 100))"/>
                                                <s t-field="line.price_unit" style="color: red;" t-options='{"widget": "integer"}'/>
                                            </t>
                                            <t t-else="">
                                                <span t-field="line.price_unit" t-options='{"widget": "integer"}'/>
                                            </t>
                                        </td>
                                        <td name="td_subtotal" class="text-end o_price_total">
                                            <span t-field="line.price_subtotal" t-options='{"widget": "integer"}'/>
                                            <span t-field="line.currency_id.symbol"/>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                            <tr style="background-color: #f0f1f2; table-borderless">
                                <td/>
                                <td/>
                                <td/>
                                <td/>
                                <td class="text-end">
                                    <span t-esc="int(total_qty)"/>
                                </td>
                                <td/>
                                <td class="text-end o_price_total">
                                    <span t-esc="int(total_amount)"/>
                                    <span t-field="doc.currency_id.symbol"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="clearfix" style="page-break-inside: avoid;" name="so_total_summary" dir="rtl">
                        <div class="row">
                            <div class="col-6" style="padding: 5px">
                                <table style="background-color: #f0f1f2;" class="table table-sm table-borderless">
                                    <tr>
                                        <td>طريقة الدفع</td>
                                        <td>
                                            <t t-set="payments" t-value="doc.mapped('mataa_payment_ids.code')"/>
                                            <t t-set="count" t-value="len(payments)"/>
                                            <t t-set="index" t-value="0"/>

                                            <t t-foreach="payments" t-as="pay">
                                                <t t-set="index" t-value="index + 1"/>

                                                <t t-if="pay == 'cod'"><span>الدفع عند الاستلام</span></t>
                                                <t t-elif="pay == 'walle'"><span>محفظة</span></t>
                                                <t t-elif="pay == 'pypal'"><span>باي بال</span></t>
                                                <t t-elif="pay == 'MOA'"><span>معاملات</span></t>
                                                <t t-elif="pay == 'MSP'"><span>مصرفي باي</span></t>
                                                <t t-elif="pay == 'MBC'"><span>موبي كاش</span></t>
                                                <t t-elif="pay == 'YSR'"><span>يسر باي</span></t>
                                                <t t-elif="pay == 'edf'"><span>إدفع لي</span></t>
                                                <t t-elif="pay == 'tlync'"><span>تي لينك</span></t>
                                                <t t-else=""><span>غير محدد</span></t>

                                                <t t-if="index &lt; count">، </t>
                                            </t>
                                        </td>
                                    </tr>
<!--                                        <td>كوبون</td>-->
<!--                                        <td>-->
<!--                                            <span t-esc="', '.join(doc.mapped('mataa_coupon_ids.display_name'))"/>-->
<!--                                        </td>-->
                                </table>
                            </div>
                            <div class="col-6" style="padding: 5px">
                                <div style="float: left; border-right: 2px solid #a1a6ad;">
                                    <table class="text-right table-borderless" style="margin-right:5px;padding-right:5px;">
                                        <tr>
                                            <td style="width: 100px; height:20px;">التخفيض</td>
                                            <td style="width: 40px;">
                                                <t t-set="coupon" t-value="sum(doc.mapped('mataa_coupon_ids.amount_deducted'))"/>
                                                <span t-if="coupon>0"> - </span>
                                                <span t-esc="int(coupon)"/>
                                            </td>
                                        </tr>
                                        <tr t-if="doc.get_total_e_payments() > 0">
                                            <td style="width: 100px;height:20px;">اﻟﻤﺤﻔﻈﺔ</td>
                                            <td style="width: 40px;">
                                                <t t-set="tot_pay" t-value="doc.get_total_e_payments()"/>
                                                <span t-if="tot_pay>0"> - </span>
                                                <span t-esc="int(tot_pay)"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="width: 100px;height:20px;">التوصيل</td>
                                            <td style="width: 40px;">
                                                <t t-set="shipping" t-value="doc.get_shipping_price()"/>
                                                <span t-if="shipping>0"> + </span>
                                                <span t-esc="int(shipping)"/>
                                            </td>
                                        </tr>
                                        <tr style="border-top: 2px solid #a1a6ad;">
                                            <td style="width: 100px;height:20px;"><b>المجموع</b></td>
                                            <td style="width: 40px;">
                                                <b t-esc="int(doc.get_shipment_price())"/>
                                            </td>
                                        </tr>

                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="oe_structure"/>

                </div>
            </t>
        </template>


        <template id="mataa_report_saleorder">

            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="mataa_order_management.mataa_report_saleorder_document" t-lang="doc.partner_id.lang"/>
                </t>
            </t>

        </template>

    </data>
</odoo>
