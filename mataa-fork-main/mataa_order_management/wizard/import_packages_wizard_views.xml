<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_import_packages_wizard" model="ir.ui.view">
            <field name="name">import.packages.wizard.form</field>
            <field name="model">import.packages.wizard</field>
            <field name="arch" type="xml">
                <form string="Import POs">
                    <group>
                        <field name="import_file" widget="binary" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                        <field name="picking_id" invisible="1"/>

                        <p style="text-align: justify; margin-left: 20px; margin-top: 10px; width: 300px;">
                            You can download an example Excel template by clicking:
                            <br/>
                            <a href="/mataa_order_management/static/src/downloads/import_packages_template.xlsx?v=1"
                               target="_blank"
                               style="display: inline-block; margin-top: 10px; text-decoration: underline; font-weight: bold;">
                                Download Template
                            </a>.
                        </p>
                    </group>
                    <footer>
                        <button string="Import" type="object" name="import_packages" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_import_packages" model="ir.actions.act_window">
            <field name="name">Import Products Packages</field>
            <field name="res_model">import.packages.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_stock_picking"/>
            <field name="binding_view_types">form</field>
        </record>
    </data>
</odoo>