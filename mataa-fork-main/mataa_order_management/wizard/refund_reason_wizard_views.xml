<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_refund_reason_wizard" model="ir.actions.act_window">
            <field name="name">Add Refund Reason</field>
            <field name="res_model">sale.order.refund.reason.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <record id="view_sale_order_refund_reason_wizard_form" model="ir.ui.view">
            <field name="name">sale.order.refund.reason.wizard.form</field>
            <field name="model">sale.order.refund.reason.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="refund_type"/>
                            <field name="refund_value_method"/>
                        </group>
                        <group>
                            <field name="refund_description"/>
                        </group>
                    </group>
                    
                    <field name="line_ids">
                        <tree editable="bottom" create="0" delete="1">
                            <field name="order_line_id" column_invisible="1"/>
                            <field name="product_id"/>
                            <field name="refund_reason_id" options="{'no_create_edit': True}" required="1"/>
                        </tree>
                    </field>
                    
                    <footer>
                        <button name="confirm_refund_and_process" string="Confirm Refund" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>