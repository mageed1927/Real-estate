<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vendor_bill_discount_wizard_form" model="ir.ui.view">
        <field name="name">vendor.bill.discount.wizard.form</field>
        <field name="model">vendor.bill.discount.wizard</field>
        <field name="arch" type="xml">
            <form string="Apply Retroactive Discount">
                <group>
                    <group>
                        <field name="move_id"/>
                    </group>
                    <group>
                        <field name="journal_id" options="{'no_create': True}"/>
                    </group>
                </group>
                <p class="text-muted">
                    Enter the "Qty to Disc." and "Disc./Unit". The Total Discount will be calculated automatically.
                </p>
                <field name="line_ids">
                    <tree editable="bottom" create="0" delete="0">
                        <field name="product_id" force_save="1" readonly="1" width="30%"/>
                        <field name="quantity" string="Bill Qty" force_save="1" readonly="1" optional="show"/>
                        <field name="discounted_qty" string="Qty Affected"/>
                        <field name="discount_unit" string="Disc./Unit"/>
                        <field name="discount_amount" string="Total Value" sum="Total Discount" force_save="1" readonly="1"/>
                    </tree>
                </field>
                <footer>
                    <button string="Apply Discount" name="action_apply_discount" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_vendor_bill_discount" model="ir.actions.act_window">
        <field name="name">Retroactive Discount</field>
        <field name="res_model">vendor.bill.discount.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">form</field>
    </record>

    <record id="view_move_form_inherit_discount" model="ir.ui.view">
        <field name="name">account.move.form.inherit.discount</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(action_vendor_bill_discount)d"
                        string="Retroactive Discount"
                        type="action"
                        groups="account.group_account_invoice"
                        invisible="move_type != 'in_invoice' or state != 'posted'"/>
            </xpath>
        </field>
    </record>
</odoo>