<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_switch_payment_method_wizard_form" model="ir.ui.view">
      <field name="name">switch.payment.method.wizard.form</field>
      <field name="model">switch.payment.method.wizard</field>
      <field name="arch" type="xml">
        <form string="Switch Payment Method">
          <group>
            <field name="sale_order_id"/>
            <field name="currency_id" invisible="1"/>
            <field name="is_cod_to_wallet" invisible="1"/>
            <field name="use_existing_payment" 
                   invisible="not is_cod_to_wallet"/>
            <field name="existing_payment_id"
                   domain="[('sale_order_id', '=', sale_order_id), ('code', '=', wallet_journal_code)]"
                   invisible="not use_existing_payment or not is_cod_to_wallet"
                   required="use_existing_payment"/>
            <field name="amount"/>
            <field name="wallet_journal_code" invisible="1"/>
          </group>
          <footer>
            <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
            <button string="Cancel" class="btn-secondary" special="cancel"/>
          </footer>
        </form>
      </field>
    </record>

    <record id="action_switch_payment_method_wizard" model="ir.actions.act_window">
      <field name="name">Switch Payment Method</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">switch.payment.method.wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
      <field name="context">{}</field>
    </record>

  </data>
</odoo>
