<odoo>
    <record id="view_order_cancel_wizard_form" model="ir.ui.view">
        <field name="name">order.cancel.wizard.form</field>
        <field name="model">order.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancel Order">
                <group>
                    <field name="reason_ids" widget="many2many_tags"/>
                    <field name="note"/>
                </group>
                <footer>
                    <button string="Continue"
                            type="object"
                            name="action_confirm_cancel"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
