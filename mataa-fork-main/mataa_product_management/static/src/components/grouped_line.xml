<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="stock_barcode.GroupedLineComponent" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_barcode_line_details')]" position="before">
            <span class="d-inline-block ms-1">
            <img
                loading="lazy"
                class="img img-fluid oe_avatar"
                alt="Binary file"
                width="80"
                t-att-src="line.product_id.main_image"
                t-att-name="props.name"
                t-att-style="sizeStyle"
                t-on-error.stop="onLoadFailed"
                t-att-data-tooltip-template="hasTooltip and tooltipAttributes.template"
                t-att-data-tooltip-info="hasTooltip and tooltipAttributes.info"
                t-att-data-tooltip-delay="hasTooltip and props.zoomDelay"
            />

            </span>
</xpath>
    </t>

    <t t-inherit="stock_barcode.LineComponent" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_line_buttons')]" position="inside">

            <span class="d-inline-block ms-1">
              <t t-if="line.product_id.main_image">
            <img
                loading="lazy"
                class="img img-fluid oe_avatar"
                alt="Binary file"
                width="80"
                t-att-src="line.product_id.main_image"
                t-att-name="props.name"
                t-att-style="sizeStyle"
                t-on-error.stop="(ev) => {
                ev.currentTarget.classList.add('d-none');
                 ev.currentTarget.nextElementSibling?.classList.remove('d-none');
             }"
                t-att-data-tooltip-template="hasTooltip and tooltipAttributes.template"
                t-att-data-tooltip-info="hasTooltip and tooltipAttributes.info"
                t-att-data-tooltip-delay="hasTooltip and props.zoomDelay"
            />
            <span class="d-none ms-1">Broken Image URL</span>
          </t>
          <t t-else="">
            <span class=" ms-1">No Image</span>
          </t>
            </span>
        </xpath>
        <xpath expr="//div[hasclass('o_line_buttons')]/span[1]" position="attributes">
            <attribute name="t-if">env.model.getDisplayButtons(line)</attribute>
        </xpath>
        <xpath expr="//div[hasclass('o_line_buttons')]/span[2]" position="attributes">
            <attribute name="t-if">env.model.getDisplayButtons(line)</attribute>
        </xpath>
    </t>

</templates>
