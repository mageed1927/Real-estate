<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_product_brand_form_mataa" model="ir.ui.view">
            <field name="name">product.brand.form.mataa</field>
            <field name="model">product.brand</field>
            <field name="inherit_id" ref="product_brand.view_product_brand_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='logo']" position="before">
                    <field name="logo_url" invisible="1"/>
                </xpath>

                <xpath expr="//field[@name='logo']" position="replace">
                    <field name="logo_url" widget="image_url" style="max-width: 300px; max-height: 300px;"
                           invisible="logo_url == False"/>
                    <button name="clear_image" type="object" string="Clear Image" class="btn-link"
                            invisible="logo_url == False"/>
                    <field name="logo" widget="image" style="max-width: 300px; max-height: 300px;"
                           invisible="logo_url != False"/>
                </xpath>
                <xpath expr="//field[@name='logo']" position="after">
                    <field name="seo_keyword_ids" widget="many2many_tags" string="SEO Keywords"
                            placeholder="Add SEO keywords..." options="{'no_create_edit': True}"/>
                    <button name="force_propagate_seo_keywords" type="object" string="Force Propagate SEOs" class="btn-primary"/>
                </xpath>

            </field>
        </record>

        <record id="product_brand_kanban_view_inherit_mataa" model="ir.ui.view">
            <field name="name">product.brand.kanban.inherit.mataa</field>
            <field name="model">product.brand</field>
            <field name="inherit_id" ref="product_brand.view_product_brand_kanban"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='logo']" position="before">
                    <field name="logo_url" invisible="1"/>
                </xpath>

                <xpath expr="//div[hasclass('o_kanban_image')]/img" position="replace">
                    <img t-att-src="record.logo_url and record.logo_url.raw_value or '/web/static/img/placeholder.png'"
                         alt="Brand" class="o_kanban_image_fill_left"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>