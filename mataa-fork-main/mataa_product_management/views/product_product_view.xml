<odoo>
    <data>
        <record id="view_product_product_tree_mataa" model="ir.ui.view">
            <field name="name">product.product.tree.mataa</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_product_tree_view"/>
            <field name="arch" type="xml">
                <xpath expr="//tree" position="inside">
                    <!-- nothing yet -->
                </xpath>
            </field>
        </record>
    </data>

    <record id="product_variant_easy_edit_view_mataa" model="ir.ui.view">
        <field name="name">product.variant.easy.edit.view.mataa</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_variant_easy_edit_view"/>
        <field name="arch" type="xml">
            <xpath expr="//label[@for='lst_price']" position="before">
                <label for="regular_price" string="Regular Price"/>
                <div name="pricing" class="o_row">
                    <field name="regular_price" class="oe_inline" widget='monetary'
                           options="{'currency_field': 'currency_id'}"/>
                </div>
            </xpath>
        </field>
    </record>

    <record id="view_product_product_supplier_inherit_mataa" model="ir.ui.view">
        <field name="name">view.product.product.supplier.inherit.mataa</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="purchase.view_product_product_supplier_inherit"/>
        <field name="arch" type="xml">
            <field name="seller_ids" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="variant_seller_ids" position="attributes">
                <attribute name="invisible">0</attribute>
                <attribute name="readonly">0</attribute>
            </field>
        </field>
        </record>

    <record id="product_normal_form_view_inherit" model="ir.ui.view">
        <field name="name">product.product.form.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='description']/.." position="before">
                <label for="variant_image_url_ids" string="Variant images"/>
                <field name="variant_image_url_ids">
                    <tree editable="bottom" default_order="sequence asc">
                        <field name="sequence" widget="handle"/>
                        <field invisible="id == False" name="link_html" widget="html"/>
                        <field invisible="id == False" name="url" widget="image_url" string="Images"
                               style="width: 150px; height: 150px; object-fit: cover;"/>
                        <field invisible="id != False" name="file_data" filename="file_name" widget="binary"
                               options="{'accepted_file_extensions': '.jpeg,.jpg,.png,.gif,.bmp,.tiff,.tif,.svg,.ico,.webp'}"/>
                        <field name="file_name" invisible="1"/>
                    </tree>
                </field>
            </xpath>
        </field>
    </record>

    <!-- Add actions server -->
    <record id="action_custom_export_product" model="ir.actions.server">
        <field name="name">Custom export</field>
        <field name="model_id" ref="product.model_product_product"/>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = {
                'type': 'ir.actions.act_url',
                'url': '/export/products/%s' % env.context.get('active_ids'),
                'target': 'new',
            }
        </field>
    </record>

    <record id="view_product_variant_price_security_mataa" model="ir.ui.view">
        <field name="name">product.variant.price.security.mataa</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lst_price']" position="before">
                <field name="is_price_manager" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='lst_price']" position="attributes">
                <attribute name="readonly">not is_price_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='regular_price']" position="attributes">
                <attribute name="readonly">not is_price_manager</attribute>
            </xpath>
        </field>
    </record>
    <record id="view_product_variant_easy_price_security_mataa" model="ir.ui.view">
        <field name="name">product.variant.easy.price.security.mataa</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_variant_easy_edit_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lst_price']" position="before">
                <field name="is_price_manager" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='regular_price']" position="attributes">
                <attribute name="readonly">not is_price_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='lst_price']" position="attributes">
                <attribute name="readonly">not is_price_manager</attribute>
            </xpath>
        </field>
    </record>

</odoo>
