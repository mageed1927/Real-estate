<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_import_po_wizard" model="ir.ui.view">
            <field name="name">import.po.wizard.form</field>
            <field name="model">import.po.wizard</field>
            <field name="arch" type="xml">
                <form string="Import POs">
                    <group>
                        <field name="import_file" widget="binary" filename="file_name"/>
                        <field name="file_name" invisible="1"/>

                        <p style="text-align: justify; margin-left: 20px; margin-top: 10px; width: 300px;">
                            You can download an example Excel template by clicking:
                            <br/>
                            <a href="/mataa_advanced_import/static/src/downloads/advanced_import_po_template.xlsx?v=1"
                               target="_blank"
                               style="display: inline-block; margin-top: 10px; text-decoration: underline; font-weight: bold;">
                                Download Template
                            </a>.
                        </p>
                    </group>
                    <footer>
                        <button string="Import" type="object" name="import_po" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_import_variants" model="ir.actions.act_window">
            <field name="name">Import Product Variants</field>
            <field name="res_model">import.variants.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_import_variants"
                  name="Import Variants"
                  parent="menu_advanced_import_root"
                  action="action_import_variants"
                  sequence="13"/>
    </data>
</odoo>