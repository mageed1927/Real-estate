<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_import_main_wizard" model="ir.ui.view">
            <field name="name">import.main.wizard.form</field>
            <field name="model">import.main.wizard</field>
            <field name="arch" type="xml">
                <form string="Import Main Wizard">
                    <group col="4">
                        <group>
                            <button name="action_open_import_variants"
                                    string="Import Variants (Advanced)"
                                    type="object"
                                    class="btn-secondary"/>
                        </group>
                        <group>
                            <button name="action_open_import_po"
                                    string="Import PO"
                                    type="object"
                                    class="btn-secondary"/>
                        </group>
                        <group>
                            <button name="action_open_import_quick"
                                    string="Quick Product Import "
                                    type="object"
                                    class="btn-secondary"/>
                        </group>
                        <group>
                            <button name="%(log_imports_action)s"
                                    string="History imports"
                                    type="action"
                                    class="btn-secondary"/>
                        </group>
                    </group>
                    <separator string="EMS Sync Issue Reports" style="margin-top: 30px;"/>
                    <group col="3">
                        <group>
                            <button name="action_download_ems_daily"
                                    string="Download Daily Report"
                                    type="object"
                                    class="btn-primary"
                                    icon="fa-download"/>
                        </group>

                        <group/>
                        <group>
                            <button name="action_download_ems_monthly"
                                    string="Download Monthly Report"
                                    type="object"
                                    class="btn-primary"
                                    icon="fa-download"/>
                        </group>
                    </group>
                </form>
            </field>
        </record>

        <!-- Action to open the main view with two buttons -->
        <record id="action_import_main_wizard" model="ir.actions.act_window">
            <field name="name">Import Main Wizard</field>
            <field name="res_model">import.main.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_import_main_wizard"/>
            <field name="target">new</field>
        </record>

        <menuitem name="Advanced Import"
                  id="menu_advanced_import_root"
                  sequence="10"
                  web_icon="mataa_advanced_import,static/description/icon.png"/>

        <menuitem id="menu_import_main_wizard"
                  name="Import Main Wizard"
                  parent="menu_advanced_import_root"
                  action="action_import_main_wizard"
                  sequence="11"/>
    </data>
</odoo>