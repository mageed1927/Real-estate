<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_precreation_employee_tree" model="ir.ui.view">
        <field name="name">mataa.precreation.employee.tree</field>
        <field name="model">mataa.precreation.employee</field>
        <field name="arch" type="xml">
            <tree editable="top">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="action_precreation_employee" model="ir.actions.act_window">
        <field name="name">Pre-creation Employee</field>
        <field name="res_model">mataa.precreation.employee</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem id="menu_mataa_hr_root" 
              name="Employees"
              groups="mataa_hr.group_precreation_employee"
              web_icon="hr,static/description/icon.png"
              sequence="75"/>

    <menuitem id="menu_precreation_employee"
              name="Create New Employee"
              action="action_precreation_employee"
              parent="menu_mataa_hr_root"
              sequence="10"/>
</odoo>