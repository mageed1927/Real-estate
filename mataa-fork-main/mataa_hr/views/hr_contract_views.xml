<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_contract_view_form_inherit_salary_items" model="ir.ui.view">
        <field name="name">hr.contract.view.form.inherit.salary.items</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Salary Items" name="salary_items">

                    <separator string="Fixed Allowances" />
                    <field name="allowance_ids">
                        <tree editable="bottom">
                            <field name="salary_rule_id" options="{'no_create': True}"/>
                            <field name="amount"/>
                            <field name="note"/>
                        </tree>
                    </field>

                  <separator string="Monthly Deductions" style="margin-top: 20px;"/>

                    <div class="o_row">
                        <label for="display_deduction_history" class="fw-bold"/>
                        <field name="display_deduction_history" widget="boolean_toggle"/>
                    </div>

                    <field name="deduction_ids" domain="[('is_processed', '=', False)]" invisible="display_deduction_history">
                        <tree editable="bottom" decoration-danger="date &lt; current_date">
                            <field name="date"/>
                            <field name="salary_rule_id" options="{'no_create': True}"/>
                            <field name="amount" sum="Total"/>
                            <field name="note"/>
                            <field name="is_processed" column_invisible="1"/>
                        </tree>
                    </field>

                    <field name="deduction_history_ids" invisible="not display_deduction_history">
                        <tree editable="bottom" decoration-muted="is_processed" decoration-info="not is_processed">
                            <field name="date"/>
                            <field name="salary_rule_id" options="{'no_create': True}"/>
                            <field name="amount" sum="Total"/>
                            <field name="note"/>
                            <field name="is_processed" widget="boolean_toggle" readonly="1"/>
                        </tree>
                    </field>

                </page>
            </xpath>
        </field>
    </record>
</odoo>