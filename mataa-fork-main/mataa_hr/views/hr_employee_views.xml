<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_financial" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.financial</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='public']//group" position="inside">
                <group string="Financial Settings" name="financial_settings">
                    <field name="work_contact_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>