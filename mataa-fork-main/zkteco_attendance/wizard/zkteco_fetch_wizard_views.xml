<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_ztkeco_fetch_wizard_form" model="ir.ui.view">
        <field name="name">ztkeco.fetch.wizard.form</field>
        <field name="model">ztkeco.fetch.wizard</field>
        <field name="arch" type="xml">
            <form string="جلب بصمات ZKTeco">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="employees" widget="many2many_tags" options="{'no_create': True, 'no_quick_create': True}"/>
                </group>
                <footer>
                    <button name="action_fetch_and_process" type="object" string="جلب ومعالجة" class="btn-primary"/>
                    <button string="إلغاء" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ztkeco_fetch_wizard" model="ir.actions.act_window">
        <field name="name">جلب بصمات ZKTeco</field>
        <field name="res_model">ztkeco.fetch.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
