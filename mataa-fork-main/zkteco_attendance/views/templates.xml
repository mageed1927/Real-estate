<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="kiosk_page" name="Employee Kiosk Page">
        <t t-call="website.layout">
            <div class="container py-5">
                <h2 class="mb-4 text-center">كشف حضور الموظف</h2>

                <div class="mb-4">
                    <form action="/employee_kiosk/login" method="POST" class="mx-auto" style="max-width: 400px;">
                        <div class="mb-3">
                            <input type="password" name="pin" class="form-control" placeholder="Enter your PIN" required="required"/>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">تأكيد</button>
                    </form>
                </div>

                <t t-if="request.params.get('error') == 'invalid_pin'">
                    <div class="alert alert-danger text-center" role="alert">
                        Invalid PIN. Please try again.
                    </div>
                </t>
            </div>
        </t>
    </template>

    <template id="employee_pin_input" name="Employee PIN Input">
        <t t-call="website.layout">
            <div class="container py-5">
                <h2 class="mb-4 text-center">Enter PIN for <t t-esc="employee.name" /></h2>

                <form action="/employee_kiosk/login" method="POST">
                    <input type="hidden" name="employee_id" t-att-value="employee.id"/>
                    <div class="mb-2">
                        <input type="password" name="pin" class="form-control" placeholder="Enter PIN" required="required"/>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Login</button>
                </form>
            </div>
        </t>
    </template>

    <template id="employee_attendance" name="Employee Attendance View">
        <t t-call="website.layout">
            <div class="container py-5">
                <h2 class="mb-4 text-center">
                    Attendance for <t t-esc="employee.name"/>
                </h2>

                <div class="table-responsive">
                    <table class="table table-striped table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Check In</th>
                                <th>Check Out</th>
                                <th>Plus Hours</th>
                                <th>Negative Hours</th>
                                <th>Early In</th>
                                <th>Early Out</th>
                                <th>Late In</th>
                                <th>Late Out</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="attendance_data" t-as="rec">
                                <t t-if="isinstance(rec, dict)">
                                    <tr class="table-info font-weight-bold">
                                        <td colspan="2" class="text-center">
                                            Total for <t t-esc="rec.get('month_name')"/>
                                        </td>
                                        <td><t t-esc="rec.get('total_plus')"/></td>
                                        <td><t t-esc="rec.get('total_negative')"/></td>
                                        <td><t t-esc="rec.get('total_early_in')"/></td>
                                        <td><t t-esc="rec.get('total_early_out')"/></td>
                                        <td><t t-esc="rec.get('total_late_in')"/></td>
                                        <td><t t-esc="rec.get('total_late_out')"/></td>
                                    </tr>
                                </t>
                                <t t-else="">
                                    <tr>
                                        <td>
                                            <span t-if="rec.check_in" t-esc="rec.check_in.strftime('%Y-%m-%d %H:%M')"/>
                                        </td>
                                        <td>
                                            <span t-if="rec.check_out" t-esc="rec.check_out.strftime('%Y-%m-%d %H:%M')"/>
                                        </td>
                                        <td><span t-esc="rec.plus_hours or '00:00:00'"/></td>
                                        <td><span t-esc="rec.negative_hours or '00:00:00'"/></td>
                                        <td><span t-esc="rec.early_in or '00:00:00'"/></td>
                                        <td><span t-esc="rec.early_out or '00:00:00'"/></td>
                                        <td><span t-esc="rec.late_in or '00:00:00'"/></td>
                                        <td><span t-esc="rec.late_out or '00:00:00'"/></td>
                                    </tr>
                                </t>
                            </t>
                        </tbody>
                    </table>
                </div>

                <div class="text-center mt-4">
                    <a href="/employee_kiosk" class="btn btn-secondary">Back</a>
                </div>
            </div>
        </t>
    </template>
</odoo>
