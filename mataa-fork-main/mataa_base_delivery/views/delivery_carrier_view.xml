<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_delivery_carrier_form_mataa_inherit" model="ir.ui.view">
        <field name="name">delivery.carrier.form.mataa</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='destination']" position='after'>
                <page string="Mataa Configuration" name="mataa_configuration">
                    <group>
                        <group>
                            <field name="carrier_partner_id"/>
                        </group>
                        <group>
                            <field name="cod_journal_id"/>
                        </group>
                    </group>
                </page>
            </xpath>
            <xpath expr="//field[@name='product_id']" position='after'>
                <field name="transfer_fee_product_id"/>
            </xpath>
        </field>
    </record>


</odoo>
