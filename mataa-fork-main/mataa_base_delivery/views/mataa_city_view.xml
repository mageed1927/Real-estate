<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_mataa_city_tree" model="ir.ui.view">
        <field name="name">mataa.city.tree</field>
        <field name="model">mataa.city</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_mataa_city_form" model="ir.ui.view">
        <field name="name">mataa.city.form</field>
        <field name="model">mataa.city</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group name="city_base_name">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="parent_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <!-- Search View -->
    <record id="view_mataa_city_search" model="ir.ui.view">
        <field name="name">mataa.city.search</field>
        <field name="model">mataa.city</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
                <separator/>
                <filter string="cities" domain="[('parent_id', '=', False)]" name="cities"/>
                <filter string="Areas" domain="[('parent_id', '!=', False)]" name="areas"/>
                <separator/>

                <filter string="City" name="parent_id_gb" domain="[]"
                            context="{'group_by': 'parent_id'}"/>

            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_mataa_city" model="ir.actions.act_window">
        <field name="name">Cities</field>
        <field name="res_model">mataa.city</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menuitem -->
    <menuitem id="menu_mataa_city" name="Cities"
              parent="contacts.res_partner_menu_config"
              action="action_mataa_city"
              sequence="10"/>

</odoo>
