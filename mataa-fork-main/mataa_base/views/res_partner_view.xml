<odoo>
    <data>
        <record id="view_base_mataa_res_partner_form_inherit" model="ir.ui.view">
            <field name="name">res.partner.form.base.mataa.inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='category_id']" position="after">
                <field name="vendor_category_id" widget="many2many_tags" />
            </xpath>

                <xpath expr="//div[@name='button_box']/button[1]" position="before">
                    <button class="oe_stat_button"
                            type="action"
                            name="%(account.action_account_moves_all_a)d"
                            icon="fa-money"
                            context="{'search_default_partner_id': active_id, 'default_partner_id': active_id}">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value">
                                <field name="wallet_amount" widget="statinfo"/>
                            </span>
                        </div>
                    </button>
                </xpath>
                <div name="button_box" position="inside">
                    <button class="oe_stat_button" name="action_view_related_brands" type="object"
                            icon="fa-list" invisible="brand_count == 0">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value">
                                <field name="brand_count"/>
                            </span>
                            <span class="o_stat_text">Brands</span>
                        </div>
                    </button>
                    <button name="action_open_customer_payment"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-money">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_text">شحن</span>
                            <span class="o_stat_text">محفظة</span>
                        </div>
                    </button>
                </div>

                <field name="category_id" position="after">
                    <field name="brand_ids" widget="many2many_tags"
                           options="{'no_create': True,'no_quick_create': True,'no_open': True, 'no_create_edit': True}"/>
                </field>

                <xpath expr="//sheet" position="inside">
                    <group>
                        <field name="mataa_id"/>
                    </group>
                </xpath>

                <xpath expr="//page[@name='internal_notes']" position="after">
                    <page name="personal_information_page" string="Personal Information" invisible="is_company == True">
                        <group name="personal_information_group">
                            <field name='birthdate_date'/>
                            <field name="age" invisible="birthdate_date == False"/>
                            <field name='gender' />
                        </group>
                    </page>
                </xpath>

                <xpath expr="//field[@name='vat']" position="before">
                     <group>
                        <field name="is_customer" readonly="is_supplier == True"/>
                        <field name="is_supplier" readonly="is_customer == True"/>
                     </group>
                </xpath>

            </field>
        </record>

        <record id="view_res_partner_filter_inherit_sale_order" model="ir.ui.view">
            <field name="name">res.partner.search.inherit.sale.order.count</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_res_partner_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="sale_order_count"/>
                </xpath>
            </field>
        </record>
        </data>
</odoo>