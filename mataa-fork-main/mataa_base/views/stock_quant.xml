<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_quant_tree_editable_add_draft_reservation" model="ir.ui.view">
        <field name="name">stock.quant.tree.editable.add.draft.reservation</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='reserved_quantity']" position="before">
                <field name="draft_reserved_qty" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>