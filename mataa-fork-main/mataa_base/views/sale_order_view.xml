<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="mataa_view_order_form_inherit" model="ir.ui.view">
            <field name="name">sale.order.form.inherit.brand</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">

                <xpath expr="//notebook//page[@name='order_lines']//field[@name='order_line']//tree//field[@name='product_template_id']"
                       position="after">
                    <field name="product_brand_id" optional="show"/>
                </xpath>

            </field>
        </record>
    </data>
</odoo>
