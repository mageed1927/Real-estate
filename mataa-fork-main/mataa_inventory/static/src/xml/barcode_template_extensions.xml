<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mataa_inventory_custom.BarcodeMainComponent" t-inherit="stock_barcode.MainComponent" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('o_apply_page')]" position="before">
            <button t-if="env.model.resModel === 'stock.quant' &amp;&amp; env.model.displayApplyButton"
                    t-on-click="() => env.model.confirmSurplusMoves()"
                    class="o_confirm_surplus_moves btn btn-info me-1">
                <i class="fa fa-plus-circle me-1"/> Validate Surplus
            </button>
        </xpath>
        <xpath expr="//button[hasclass('o_apply_page')]" position="before">
            <button t-if="env.model.resModel === 'stock.quant'"
                    t-on-click="() => env.model.confirmScannedMoves()"
                    class="o_confirm_scanned_moves btn btn-primary ms-1">
                <i class="fa fa-check-circle-o me-1"/> Validate
            </button>
        </xpath>
    </t>

<t t-inherit="stock_barcode.LineComponent" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_barcode_line')]" position="attributes">
            <attribute name="t-att-style">
                (env.model &amp;&amp; env.model.resModel === 'stock.quant')
                    ? ((env.model.lineIsSurplus(line)) ? 'background-color: #6ebcf5 !important;' : 
                       (env.model.lineIsFaulty(line)) ? 'background-color: #eaa0a6 !important;' : 
                       (env.model.lineIsComplete(line)) ? 'background-color: #85efa7 !important;' : 
                       'background-color: #f8f9fa !important;')
                    : ''
            </attribute>
        </xpath>
    </t>

</templates>
